{
  "name": "@khive/cli",
  "version": "0.2.8",
  "description": "khive — research knowledge graph CLI",
  "license": "Apache-2.0",
  "tasks": {
    "dev": "deno run --allow-all main.ts",
    "test": "deno test --allow-all .",
    "test:behavior": "deno test --allow-all tests/behavior/",
    "test:contract": "deno test --allow-all tests/contract/",
    "check": "deno check main.ts",
    "fmt": "deno fmt .",
    "lint": "deno lint .",
    "compile": "deno compile --allow-all --output ../dist/khive main.ts"
  },
  "imports": {
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/fs": "jsr:@std/fs@^1.0.23",
    "@std/toml": "jsr:@std/toml@^1.0.11",
    "@std/fmt": "jsr:@std/fmt@^1.0.0",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/yaml": "jsr:@std/yaml@1.1.0"
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": false,
    "semiColons": true
  }
}
