# OS
Thumbs.db
ehthumbs.db

# khive runtime data (working databases, not committed)
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# khive KG layout:
#   .khive/kg/       — committed (NDJSON + schema.yaml)
#   .khive/config.toml — committed (project config)
#   .khive/state/    — gitignored (working.db, derived from NDJSON)
.khive/state/

# Test artifacts
test_models/
test_data/
.benchmarks/

# Documentation build
docs/_build/
docs/.next/

docs/adr/_review/

# Compiled CLI binaries (built by scripts/compile.sh, not committed)
npm/bin/khive-*
# Exception: npm/bin/khive-mcp is the Node shim for the MCP binary, not a compiled binary.
!npm/bin/khive-mcp

# Codex review artifacts (local working notes, not part of the codebase)
codex_review_*.md

# Agent workflow scratch notes (some review/fix legs write these at the repo
# root as process notes; they are never part of the source tree)
implementation_notes.md

# Real-data recall benchmark corpus (extracted from khive-graph.db, never commit)
crates/khive-pack-memory/tests/fixtures/

uv.lock
pyproject.toml
# Exception: the khive-contract integration suite is a committed uv project
!tests/khive-contract/pyproject.toml
!tests/khive-contract/uv.lock

*results.json

# Pipeline ledger — written locally and uploaded as CI artifact; not committed.
perf/pipeline-ledger.csv

# Synthetic ANN regression gate ledger — written by --ci-synthetic, uploaded as CI artifact; not committed.
perf/ci-synthetic-ledger.csv

# Raw bench-run JSON files banked by bench_1m.sh / vec_bench --bank-run.
# Named {YYYYMMDD}-{sha7}-{dataset}.json; kept out of the repo to avoid large
# generated files in PRs. The perf/bench-runs/ directory is tracked via .gitkeep.
perf/bench-runs/*.json

# bench_calibrate.py output: per-invocation variance profiles + per-run
# stdout/stderr/report artifacts. Sample-dependent and local-machine-noise
# specific; not committed.
scripts/perf/calibration/

# bench_track.py trend ledger. Lives only on the dedicated `perf-data`
# branch (published by scripts/perf/publish_ledger.sh) - never committed to
# main or a feature branch.
bench-data/
.perf-data-worktree/
